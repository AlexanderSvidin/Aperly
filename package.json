{
  "name": "aperly",
  "version": "0.1.0",
  "private": true,
  "description": "Aperly Telegram Mini App MVP",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "node --env-file=.env --import tsx --test tests/home-admin.test.ts",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:setup": "npm run db:deploy && npm run db:seed",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "prettier": "^3.8.3",
    "prisma": "^6.18.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
