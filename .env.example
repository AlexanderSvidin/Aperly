# =============================================================================
# APERLY — Environment Variables
# Copy this file to .env.local for local development.
# In production (Vercel), paste these values into the Environment Variables UI.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Local dev: postgresql://postgres:postgres@localhost:5432/aperly?schema=public
# Production: get this from neon.tech → your project → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/aperly?schema=public


# -----------------------------------------------------------------------------
# TELEGRAM — Bot & Mini App
# -----------------------------------------------------------------------------

# Bot token issued by @BotFather on Telegram.
# Create a bot: open @BotFather → /newbot → follow prompts → copy token.
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmnopQRSTUVwxyz1234567890

# How long (in seconds) a Telegram initData signature stays valid.
# Default 86400 = 24 hours. Do not change unless you have a reason to.
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# Telegram username of the bot (without @), shown in the Mini App UI.
# Example: if your bot is @aperly_bot, set this to aperly_bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username


# -----------------------------------------------------------------------------
# MINI APP
# -----------------------------------------------------------------------------

# Display name of the application (shown in UI).
NEXT_PUBLIC_APP_NAME=Aperly

# The public HTTPS URL where this Next.js app is deployed.
# Local dev: http://localhost:3000
# Production: your Vercel deployment URL, e.g. https://aperly.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# The Telegram Mini App URL — used to generate deep links in push notifications.
# This is the same URL as NEXT_PUBLIC_APP_URL unless you have a custom domain.
# Must be HTTPS. Telegram will not open http:// links inside the Mini App.
NEXT_PUBLIC_MINI_APP_URL=https://your-app.vercel.app


# -----------------------------------------------------------------------------
# SESSION
# -----------------------------------------------------------------------------

# Secret key used to sign session cookies. Must be at least 32 characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_SESSION_SECRET=replace-with-a-random-string-of-at-least-32-characters


# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT ONLY
# (Never set these in production — the app will refuse to start if you do)
# -----------------------------------------------------------------------------

# Set to true to bypass Telegram auth in local dev (no real Telegram needed).
# MUST be false in production. The app throws an error if true + NODE_ENV=production.
ALLOW_DEV_TELEGRAM_FALLBACK=false

# Mirror of ALLOW_DEV_TELEGRAM_FALLBACK for the client-side SDK init check.
NEXT_PUBLIC_ENABLE_DEV_TELEGRAM_FALLBACK=false

# Optional: paste a real Telegram initData string here to test with a real account locally.
# Leave empty to use the synthetic dev user defined below.
DEV_TELEGRAM_INIT_DATA=

# Synthetic Telegram user used when ALLOW_DEV_TELEGRAM_FALLBACK=true and DEV_TELEGRAM_INIT_DATA is empty.
DEV_TELEGRAM_USER_ID=700099000
DEV_TELEGRAM_FIRST_NAME=Aperly
DEV_TELEGRAM_LAST_NAME=Dev
DEV_TELEGRAM_USERNAME=aperly_dev
DEV_TELEGRAM_LANGUAGE_CODE=ru
